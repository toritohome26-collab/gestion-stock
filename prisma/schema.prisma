generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  email        String    @unique
  plan         String    @default("free")
  isActive     Boolean   @default(true)
  alertMessage String?
  alertSentAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users           User[]
  branches        Branch[]
  categories      Category[]
  products        Product[]
  stockMovements  StockMovement[]
  sales           Sale[]
  officeSales     OfficeSale[]
  expenses        Expense[]
  integrations    Integration[]
}

model Branch {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  phone          String?
  isActive       Boolean  @default(true)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users           User[]
  products        Product[]
  stockMovements  StockMovement[]
  officeSales     OfficeSale[]
  expenses        Expense[]

  @@unique([name, organizationId])
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  name           String
  email          String
  password       String
  role           String   @default("SELLER")
  permissions    String   @default("[]")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch?         @relation(fields: [branchId], references: [id])
  stockMovements  StockMovement[]
  officeSales     OfficeSale[]
  expenses        Expense[]
  payments        Payment[]

  @@unique([email, organizationId])
}

model Category {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([name, organizationId])
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  sku            String
  name           String
  description    String?
  categoryId     String?
  costPrice      Float    @default(0)
  salePrice      Float    @default(0)
  stock          Int      @default(0)
  minStock       Int      @default(5)
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch?          @relation(fields: [branchId], references: [id])
  category        Category?        @relation(fields: [categoryId], references: [id])
  stockMovements  StockMovement[]
  saleItems       SaleItem[]
  officeSaleItems OfficeSaleItem[]
}

model StockMovement {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  productId      String
  type           String
  quantity       Int
  reason         String?
  referenceId    String?
  referenceType  String?
  notes          String?
  userId         String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
}

model Sale {
  id              String    @id @default(cuid())
  organizationId  String
  branchId        String?
  channel         String
  externalId      String?
  externalOrderId String?
  status          String    @default("pending")
  buyerName       String?
  buyerEmail      String?
  subtotal        Float     @default(0)
  commission      Float     @default(0)
  shipping        Float     @default(0)
  discount        Float     @default(0)
  total           Float     @default(0)
  netAmount       Float     @default(0)
  currency        String    @default("ARS")
  notes           String?
  syncedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        SaleItem[]

  @@unique([externalId, organizationId])
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  productId   String?
  productName String
  sku         String?
  quantity    Int
  unitPrice   Float
  total       Float

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model OfficeSale {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  saleNumber     Int
  paymentMethod  String   @default("CASH")
  subtotal       Float    @default(0)
  discount       Float    @default(0)
  total          Float    @default(0)
  notes          String?
  userId         String?
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?          @relation(fields: [branchId], references: [id])
  user         User?            @relation(fields: [userId], references: [id])
  items        OfficeSaleItem[]
}

model OfficeSaleItem {
  id           String  @id @default(cuid())
  officeSaleId String
  productId    String?
  productName  String
  quantity     Int
  unitPrice    Float
  total        Float

  officeSale OfficeSale @relation(fields: [officeSaleId], references: [id], onDelete: Cascade)
  product    Product?   @relation(fields: [productId], references: [id])
}

model Expense {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String?
  category       String    @default("GENERAL")
  description    String
  amount         Float
  currency       String    @default("ARS")
  date           DateTime  @default(now())
  dueDate        DateTime?
  isPaid         Boolean   @default(false)
  paidAt         DateTime?
  vendor         String?
  notes          String?
  userId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  payments     Payment[]
}

model Payment {
  id        String   @id @default(cuid())
  expenseId String
  amount    Float
  date      DateTime @default(now())
  method    String   @default("CASH")
  notes     String?
  userId    String?
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
}

model Integration {
  id             String    @id @default(cuid())
  organizationId String
  platform       String
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  shopId         String?
  shopName       String?
  userId         String?
  isActive       Boolean   @default(false)
  lastSync       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([platform, organizationId])
}
